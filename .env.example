# =============================================================
# Weather Advisory Agent Environment Variables Template
# Copy this file to .env and fill in your keys.
# =============================================================

# 1. API Keys (Obtain from respective provider dashboards)
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# Optional if using Gemini, or required if using Groq
GROQ_API_KEY=your_groq_api_key_here

# 2. Database Configuration (For Local Docker Postgres container)
DB_USER=postgres
DB_PASSWORD=secure_postgres_password_here
DB_NAME=weather_advisory
